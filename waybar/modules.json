{
  // Workspaces
  "hyprland/workspaces": {
    "on-scroll-up": "hyprctl dispatch workspace r-1",
    "on-scroll-down": "hyprctl dispatch workspace r+1",
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "format": "{}",
    "format-icons": {
      "urgent": "",
      "active": "",
      "default": ""
    },
    "persistent-workspaces": {
      "*": 5
    }
    },

    // Taskbar
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "ignore-list": [
           "Alacritty"
        ],
    },

    // Hyprland Window
    "hyprland/window": {
        "rewrite": {
            "(.*) - Brave": "$1",
            "(.*) - Chromium": "$1",
            "(.*) - Brave Search": "$1",
            "(.*) - Outlook": "$1",
            "(.*) - Microsoft Teams": "$1"
        },
        "separate-outputs": true
    },
    
    // Cliphist
    "custom/cliphist": {
        "format": "ÔÉ™",
        "on-click": "sleep 0.1 && ~/dotfiles/scripts/cliphist.sh",
        "on-click-right": "sleep 0.1 && ~/dotfiles/scripts/cliphist.sh d",
        "on-click-middle": "sleep 0.1 && ~/dotfiles/scripts/cliphist.sh w",
        "tooltip": true,
        "tooltip-format": "Clipboard History"
    },
    
    // Terminal
    "custom/terminal": {
    "format": "ÔĄ†",
    "on-click": "alacritty",
    //"format-icons": ["ÔĄ†"]
    "tooltip": true,
    "tooltip-format": "Terminal"
    },

    // Screen Recorder
    "custom/wf-recorder": {
        "format": "{} ",
        "interval": "once",
        "exec": "~/dotfiles/hypr/scripts/wf-record-text.py",
        "return-type": "json",
        "tooltip": "true",
        "exec-if": "pgrep 'wf-recorder'",
        "on-click": "exec ~/dotfiles/hypr/scripts/wf-record-stop.sh",
        "signal": 8
    },
    
    // Updates Count
    "custom/updates": {
        "format": "Ôāę  {}",
        "tooltip-format": "{}",
        "escape": true,
        "return-type": "json",       
        "exec": "~/dotfiles/scripts/updates.sh",
        "restart-interval": 60,
        "on-click": "alacritty -o window.dimensions.lines=45 window.dimensions.columns=90 --class floating -e ~/dotfiles/scripts/installupdates.sh",
        "tooltip": false
    },
    
    // Wallpaper
    "custom/wallpaper": {
        "format": "ÔÄĺ",
        "on-click": "~/dotfiles/hypr/scripts/matuwall-toggle.sh",
        "on-click-right": "~/dotfiles/scripts/updatewal-awww.sh",
        "tooltip": true,
        "tooltip-format": "Wallpaper Switcher"
    },

    // Waybar Theme
    "custom/waybarthemes": {
        "format": "ÔčĎ",
        "on-click": "~/dotfiles/waybar/themeswitcher.sh",
        "tooltip": true,
        "tooltip-format": "Waybar Theme Switcher"
    },

    // Icon Theme
    "custom/iconthemes": {
        "format": "ÔĀĽ",
        "on-click": "~/dotfiles/scripts/icon-color-select.sh",
        "tooltip": true,
        "tooltip-format": "Folder Theme Switcher"
    },

        // Set sddm & grub to current wallpaper
    "custom/sddmgrub": {
        "format": "ÔČą",
        "on-click": "alacritty -o window.dimensions.lines=45 window.dimensions.columns=90 --class floating -e ~/dotfiles/sddm/update.sh",
        "tooltip": true,
        "tooltip-format": "sddm/grub updater"
    },

    // Filemanager Launcher
    "custom/filemanager": {
        "format": "ūüóĀ",
        "on-click": "~/dotfiles/scripts/filemanager.sh",
        "tooltip": true,
        "tooltip-format": "File Manager"
    },

    // ChatGPT Launcher
    "custom/chatgpt": {
        "format": "ÔÜĚ",
        "on-click": "brave --app=https://chat.openai.com",
        "tooltip": false
    },

    // Rofi Calculator
    "custom/calculator": {
        "format": "Ôá¨",
        "on-click": "~/dotfiles/scripts/calculator.sh",
        "tooltip": false
    },

    // Rofi Application Launcher
    "custom/appmenu": {
        "format": "ÔÄē Home",
        "on-click": "~/dotfiles/scripts/applauncher.sh",
        "tooltip": true,
        "tooltip-format": "Application Launcher"
    },

    // Power Menu
    "custom/exit": {
        "format": "ÔÄĎ",
        "on-click": "~/dotfiles/hyprlogout/logout.sh",
        "tooltip": false
    },

    // Screenshot
    "custom/screenshot": {
        "format": "ÔāÉ",
        "on-click": "~/dotfiles/scripts/screenshot.sh",
        "tooltip": true,
        "tooltip-format": "Take a Screenshot"
    },

    // System tray
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },

    // Clock
    "clock": {
        // "timezone": "Europe/London",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%d-%m-%y}"
    },

    // custom keybooard state
      "custom/kbstate": {
        "return-type": "json",
        "exec": "~/dotfiles/scripts/keyboard_state.sh",
        "restart-interval": 5,
        "hide-empty-text": true
    },
    
    // CPU
    "cpu": {
        "format": "ůįćõ   {usage}% ",
        "on-click": "alacritty -e btop"
    },

    // Memory
    "memory": {
        "format": "ůįĺÜ   {}% ",
        "on-click": "alacritty -e btop"
    },

    // Harddisc space used
    "disk": {
        "interval": 30,
        "format": "ůįčä   {percentage_used}% ",
        "path": "/",
        "on-click": "alacritty -e btop"
    }, 
    
    // Network
    "network": {
        "format": "{ifname}",
        "format-wifi": "{essid} Ôáę {signalStrength}%",
        "format-ethernet": "ÔõŅ {ipaddr}/{cidr}",
        "format-linked": "ÔõŅ {ifname} (No IP)",
        "format-disconnected": "Ô™© Disconnected",
        "format-disabled": "Ô™© Disabled",
        "format-alt": "ÔÉė {bandwidthUpBits} | ÔÉó {bandwidthDownBits}",
        "tooltip-format": "ÔěĖ {ifname} via {gwaddri}",
        "tooltip-format-wifi": "Ôáę   {essid} ({signalStrength}%) {ifname} via {gwaddri}",
        "tooltip-format-ethernet": "ÔÉĀ  {ifname} ({ipaddr}/{cidr})",
        "tooltip-format-disconnected": "Disconnected",
        "interval": 5,
        "on-click-right": "nm-connection-editor",
    },

    // Battery
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}   {capacity}%",
        "format-charging": "Ôóß  {capacity}%",
        "format-plugged": "Ôá¶  {capacity}%",
        "format-alt": "{icon}  {time}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["ÔČĄ ", "ÔČÉ ", "ÔČā ", "ÔČĀ ", "ÔČÄ "]
    },

    // Pulseaudio
    "pulseaudio": {
        "scroll-step": 5, // %, can be a float
        "format": "{icon} {volume}%",
        "format-bluetooth": "{volume}% {icon}ÔäĒ {format_source}",
        "format-bluetooth-muted": "Ôö© {icon}ÔäĒ {format_source}",
        "format-muted": "Ôö© {format_source}",
        "format-source": "{volume}% ÔĄį",
        "format-source-muted": "ÔĄĪ",
            "on-click-right": "~/dotfiles/scripts/Volume.sh --toggle-mute",
            "on-click": "pavucontrol -t 3",
        "format-icons": {
            "headphone": "ÔÄ•",
            "hands-free": "ÔĖź",
            "headset": "ÔĖź",
            "phone": "Ôāē",
            "portable": "Ôāē",
            "car": "ÔÜĻ",
            "default": ["ÔÄ¶", "ÔÄ® ", "ÔÄ® "],
            "on-scroll-up": "~/dotfiles/scripts/Volume.sh --volume-inc",
            "on-scroll-down": "~/dotfiles/scripts/Volume.sh --volume-dec",
            "scroll-step": 5,  
        },
    },

    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "ÔĄį {volume}%",
        "format-source-muted": "ÔĄĪ",
            "on-click-right": "~/dotfiles/scripts/Volume.sh --toggle-mic",
            "on-click": "pavucontrol -t 4",
            "on-scroll-up": "~/dotfiles/scripts/Volume.sh --mic-inc",
            "on-scroll-down": "~/dotfiles/scripts/Volume.sh --mic-dec",
            "scroll-step": 5,
        },

    // Bluetooth
    "bluetooth": {
        "format-disabled": "",
        "format-off": "",
        "interval": 30,
        "on-click": "blueman-manager"
    },

    //keybindings
    "custom/keybindings": {
    "format": "Ôäú",
    "on-click": "~/dotfiles/scripts/keyhint.sh",
    "tooltip": true,
    "tooltip-format": "Keybinding Help"
    },
    
    // browser
    "custom/browser": {
        "format": "Ôā¨",
        "on-click": "exec brave", //choose a browser
        "tooltip": true,
        "tooltip-format": "Web Browser"
    },

    // Other
    "user": {
        "format": "{user}",
        "interval": 60,
        "icon": false,
    }
}
