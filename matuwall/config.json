{
    "main": {
        "wallpaper_dir": "~/Pictures/Wallpapers",
        "thumbnail_size": 300,
        "mouse_enabled": true,
        "keep_ui_alive": true
    },
    "wall": {
        "wall_mode_only": true,
        "wall_awww_flags": "--transition-type random --transition-duration 2 --transition-fps 60"
