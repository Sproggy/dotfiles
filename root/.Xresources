! X colors.
! Generated by 'wal'
*foreground:        #c2c3c7
*background:        #0d1020
*.foreground:       #c2c3c7
*.background:       #0d1020
emacs*foreground:   #c2c3c7
emacs*background:   #0d1020
URxvt*foreground:   #c2c3c7
XTerm*foreground:   #c2c3c7
UXTerm*foreground:  #c2c3c7
URxvt*background:   [100]#0d1020
XTerm*background:   #0d1020
UXTerm*background:  #0d1020
URxvt*cursorColor:  #c2c3c7
XTerm*cursorColor:  #c2c3c7
UXTerm*cursorColor: #c2c3c7
URxvt*borderColor:  [100]#0d1020

! Colors 0-15.
*.color0: #0d1020
*color0:  #0d1020
*.color1: #54576A
*color1:  #54576A
*.color2: #BF3620
*color2:  #BF3620
*.color3: #B49D4B
*color3:  #B49D4B
*.color4: #646B8B
*color4:  #646B8B
*.color5: #6A7AC6
*color5:  #6A7AC6
*.color6: #A59FAD
*color6:  #A59FAD
*.color7: #c2c3c7
*color7:  #c2c3c7
*.color8: #5d6071
*color8:  #5d6071
*.color9: #54576A
*color9:  #54576A
*.color10: #BF3620
*color10:  #BF3620
*.color11: #B49D4B
*color11:  #B49D4B
*.color12: #646B8B
*color12:  #646B8B
*.color13: #6A7AC6
*color13:  #6A7AC6
*.color14: #A59FAD
*color14:  #A59FAD
*.color15: #c2c3c7
*color15:  #c2c3c7

! Black color that will not be affected by bold highlighting.
*.color66: #0d1020
*color66:  #0d1020

! Xclock colors.
XClock*foreground: #c2c3c7
XClock*background: #0d1020
XClock*majorColor:  rgba:c2/c3/c7/ff
XClock*minorColor:  rgba:c2/c3/c7/ff
XClock*hourColor:   rgba:c2/c3/c7/ff
XClock*minuteColor: rgba:c2/c3/c7/ff
XClock*secondColor: rgba:c2/c3/c7/ff

! Set depth to make transparency work.
URxvt*depth: 32
