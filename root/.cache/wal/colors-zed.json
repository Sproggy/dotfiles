{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0c151b90",
                "editor.background": "#0c151b90",
                "editor.foreground": "#c2c4c6",
                "text": "#c2c4c6",
                "text.muted": "#c2c4c670",
                "text.ignored": "#c2c4c640",
                "text.placeholder": "#c2c4c650",
                "ignored": "#c2c4c630",
                "element.hover": "#c2c4c630",
                "ghost_element.hover": "#5A768A30",
                "ghost_element.selected": "#5A768A30",
                "ghost_element.active": "#5A768A60",
                "border": "#0c151b",
                "editor.highlighted_line.background": "#5A768A10",
                "editor.active_line.background": "#5A768A10",
                "panel.background": "#0c151b90",
                "title_bar.background": "#0c151b90",
                "title_bar.inactive_background": "#0c151b90",
                "status_bar.background": "#0c151b90",
                "drop_target.background": "#0c151b90",
                "elevated_surface.background": "#0c151b",
                "toolbar.background": "#0c151b90",
                "tab_bar.background": "#0c151b90",
                "tab.inactive_background": "#0c151b90",
                "tab.active_background": "#5A768A30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0c151b",
                "scrollbar.thumb.background": "#5A768A",
                "editor.gutter.background": "#0c151b90",
                "terminal.background": "#0c151b10",
                "terminal.foreground": "#c2c4c6",
                "terminal.dim_foreground": "#c2c4c6",
                "terminal.bright_foreground": "#c2c4c6",
                "terminal.ansi.black": "#0c151b",
                "terminal.ansi.red": "#5A768A",
                "terminal.ansi.green": "#2593A8",
                "terminal.ansi.yellow": "#718D9C",
                "terminal.ansi.blue": "#9EA0A3",
                "terminal.ansi.magenta": "#97A6AB",
                "terminal.ansi.cyan": "#D5AB9D",
                "terminal.ansi.white": "#c2c4c6",
                "terminal.ansi.bright_black": "#5b666f",
                "terminal.ansi.bright_red": "#5A768A",
                "terminal.ansi.bright_green": "#2593A8",
                "terminal.ansi.bright_yellow": "#718D9C",
                "terminal.ansi.bright_blue": "#9EA0A3",
                "terminal.ansi.bright_magenta": "#97A6AB",
                "terminal.ansi.bright_cyan": "#D5AB9D",
                "terminal.ansi.bright_white": "#c2c4c6",
                "modified": "#5A768A",
                "syntax": {
                    "attribute": {
                        "color": "#5A768A"
                    },
                    "boolean": {
                      "color": "#2593A8"
                    },
                    "comment": {
                      "color": "#5b666f"
                    },
                    "comment.doc": {
                      "color": "#5b666f"
                    },
                    "constant": {
                      "color": "#2593A8"
                    },
                    "function": {
                      "color": "#D5AB9D"
                    },
                    "keyword": {
                      "color": "#9EA0A3"
                    },
                    "number": {
                      "color": "#97A6AB"
                    },
                    "operator": {
                      "color": "#9EA0A3"
                    },
                    "string": {
                      "color": "#5A768A"
                    },
                    "variable": {
                      "color": "#2593A8"
                    }
                },
                "players": [
                  {
                    "cursor": "#5A768A",
                    "background": "#0c151b",
                    "selection": "#5A768A30"
                  }
                ]
            }
        }
    ]
}
